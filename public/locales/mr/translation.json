  "faq": {
    "titleBadge": "FAQ",
    "title": "वारंवार विचारले जाणारे प्रश्न",
    "q1": {
      "question": "मी ज्या योजनांसाठी पात्र आहे त्या मी कशा शोधू?",
      "answer": "फक्त \"पात्रता तपासा\" वर क्लिक करा आणि तुमचे वय, व्यवसाय, उत्पन्न आणि स्थान याबद्दल काही जलद प्रश्नांची उत्तरे द्या. तुमच्या उत्तरांच्या आधारे, प्लॅटफॉर्म तुम्हाला पात्र असलेल्या सरकारी योजना दाखवेल."
    },
    "q2": {
      "question": "मला किती प्रश्नांची उत्तरे द्यावी लागतील?",
      "answer": "तुम्हाला फक्त साध्या प्रश्नांच्या संचाची (सुमारे 1-2 मिनिटे) उत्तरे द्यावी लागतील. हे प्रश्न सिस्टीमला तुमची परिस्थिती समजून घेण्यास आणि तुम्हाला संबंधित योजनांशी जोडण्यास मदत करतात."
    },
    "q3": {
      "question": "मला कोणतीही कागदपत्रे अपलोड करण्याची गरज आहे का?",
      "answer": "नाही. तुमची पात्रता तपासण्यासाठी तुम्हाला येथे कागदपत्रे अपलोड करण्याची गरज नाही. आधार कार्ड, बँक खाते तपशील किंवा रेशन कार्ड यांसारख्या कागदपत्रांची आवश्यकता फक्त तेव्हाच असू शकते जेव्हा तुम्ही अधिकृत सरकारी वेबसाइटद्वारे अर्ज करता."
    },
    "q4": {
      "question": "माझी वैयक्तिक माहिती सुरक्षित आहे का?",
      "answer": "होय. प्लॅटफॉर्म फक्त तुम्हाला संबंधित योजनांशी जोडण्यासाठी तुमच्या उत्तरांचा वापर करतो. आधार क्रमांक किंवा बँकेचे तपशील यासारखा कोणताही संवेदनशील वैयक्तिक डेटा संग्रहित केला जात नाही."
    },
    "q5": {
      "question": "मी अनेक योजनांसाठी पात्र असल्यास काय होईल?",
      "answer": "तुम्ही अनेक सरकारी कार्यक्रमांसाठी पात्र असल्यास, प्लॅटफॉर्म सर्व जुळणाऱ्या योजना त्यांच्या फायद्यांसह दाखवेल जेणेकरणून तुम्ही प्रत्येक पर्यायाचा शोध घेऊ शकाल."
    },
    "q6": {
      "question": "मला माझ्या बीपीएल स्थिती किंवा उत्पन्नाबद्दल खात्री नसल्यास मी अजूनही या प्लॅटफॉर्मचा वापर करू शकतो का?",
      "answer": "होय. तुम्हाला काही उत्तरांबद्दल खात्री नसल्यास, तरीही तुम्ही प्रश्नावली पूर्ण करू शकता. प्लॅटफॉर्म तुम्ही प्रदान केलेल्या माहितीवर आधारित योजना सुचवण्याचा प्रयत्न करेल."
    },
    "q7": {
      "question": "हे प्लॅटफॉर्म माझ्या वतीने योजनेसाठी अर्ज करते का?",
      "answer": "नाही. हे प्लॅटफॉर्म तुम्हाला ज्या योजनांसाठी तुम्ही पात्र असू शकता अशा योजना शोधण्यात मदत करते. निकाल पाहिल्यानंतर, तुम्ही अर्ज करण्यासाठी अधिकृत सरकारी वेबसाइट किंवा अर्ज पोर्टलला भेट देऊ शकता."
    }
  },
